rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net: Deny all reads and writes by default
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      // In development/preview, we might want to be more lenient or strict based on the auth provider
      // For Google Auth, email is usually verified
      return isSignedIn() && (request.auth.token.email_verified == true);
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'xp', 'level'])
          && data.xp is int && data.xp >= 0 
          && data.level is int && data.level >= 1
          && data.email is string && data.email.size() > 0
          && data.uid == userId;
      }

      allow create: if isOwner(userId) 
        && isValidUser(incoming())
        && incoming().xp == 0
        && incoming().level == 1;

      allow update: if isOwner(userId)
        && isValidUser(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['xp', 'level', 'streak', 'completedBlueprints', 'displayName']);
    }

    // --- Projects ---
    match /projects/{projectId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      // Explicit evaluation of resource.data in allow list to force query filtering
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;

      function isValidProject(data) {
        return data.userId == request.auth.uid
          && data.title is string && data.title.size() <= 200
          && data.data is map;
      }

      allow create: if isEmailVerified() && isValidId(projectId)
        && isValidProject(incoming());
      
      allow update: if isEmailVerified() && existing().userId == request.auth.uid
        && isValidProject(incoming())
        && incoming().userId == existing().userId
        && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'data', 'industry', 'techStack', 'readinessScore']);

      allow delete: if isEmailVerified() && existing().userId == request.auth.uid;
    }
  }
}
