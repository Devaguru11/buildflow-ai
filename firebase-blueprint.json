{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user profiles with gamification stats",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "xp": { "type": "integer" },
        "level": { "type": "integer" },
        "streak": { "type": "integer" },
        "completedBlueprints": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "xp", "level"]
    },
    "Project": {
      "title": "Project",
      "description": "A generated product blueprint",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "industry": { "type": "string" },
        "techStack": { "type": "array", "items": { "type": "string" } },
        "generatedAt": { "type": "string", "format": "date-time" },
        "readinessScore": { "type": "integer" },
        "data": { "type": "object" }
      },
      "required": ["userId", "title", "data"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Standalone project blueprints"
    }
  }
}
